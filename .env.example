# Runtime profile: development, cpu, or gpu
LIFELOG_ENV=development

# Local-only network defaults
LIFELOG_API_HOST=127.0.0.1
LIFELOG_API_PORT=8000

# Local storage roots
LIFELOG_DATA_DIR=./data
LIFELOG_MODEL_DIR=./models
LIFELOG_LOG_DIR=./logs
LIFELOG_SQLITE_PATH=./data/lifelog.sqlite3
LIFELOG_FFMPEG_PATH=

# Qdrant server mode is the default runtime choice for v1.0.
LIFELOG_QDRANT_URL=http://127.0.0.1:6333
LIFELOG_QDRANT_API_KEY=

# Web login (single user). Set a password to require login before any data is
# served; leave blank to disable auth (local-only use). MUST be set before
# exposing the backend through a public tunnel.
LIFELOG_AUTH_PASSWORD=
# Token signing key. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
LIFELOG_AUTH_SECRET=
# Session lifetime in seconds (default 30 days).
LIFELOG_AUTH_TTL_SECONDS=2592000

# Modalities enabled for v1.0.
LIFELOG_ENABLED_MODALITIES=text,email,photos,audio,video,calendar,browser_history

# Model choices for v1.0.
LIFELOG_TEXT_EMBEDDING_MODEL=intfloat/e5-large-v2
# Build dense e5 vectors for text/transcript chunks at ingest. OFF by default; if
# left off, semantic text search is dead and only BM25 keyword matching works.
LIFELOG_ENABLE_TEXT_EMBEDDING=true
LIFELOG_IMAGE_MODEL=ViT-L-14
LIFELOG_IMAGE_PRETRAINED=openai
LIFELOG_TRANSCRIPTION_ENGINE=whisperx
LIFELOG_TRANSCRIPTION_MODEL=large-v3
# Smaller, faster model for interactive voice-search queries (mic in the web UI).
LIFELOG_QUERY_TRANSCRIPTION_MODEL=base
LIFELOG_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Scheduling and local enrichment
LIFELOG_SCHEDULER=apscheduler
LIFELOG_ENABLE_REVERSE_GEOCODING=true
LIFELOG_OFFLINE_MODE=false

# AI enrichment (OCR, captions, tags, actions, faces) — strictly local.
# LIFELOG_ENABLE_ENRICHMENT gates the automatic/scheduled pass; per-feature flags
# control individual enrichers (run explicitly with `lifelog enrich`).
LIFELOG_ENABLE_ENRICHMENT=false
LIFELOG_ENRICH_OCR=true
LIFELOG_ENRICH_CAPTION=false
# VLM descriptions (Qwen2-VL) — reads + describes images, richer than BLIP captions.
LIFELOG_ENRICH_VLM=false
LIFELOG_ENRICH_TAGS=false
LIFELOG_ENRICH_ACTION=false
LIFELOG_ENRICH_FACES=false
LIFELOG_ENRICH_BATCH_SIZE=32
LIFELOG_OCR_LANGUAGES=en
# Captioning (Phase 1) — set a smaller VLM here for 8 GB GPUs if desired.
LIFELOG_CAPTION_MODEL=Salesforce/blip-image-captioning-base
LIFELOG_VLM_MODEL=Qwen/Qwen2-VL-2B-Instruct
# Zero-shot tags (Phase 1) — reuses the OpenCLIP image model by default.
LIFELOG_TAG_MODEL=ViT-L-14
LIFELOG_TAG_PRETRAINED=openai
LIFELOG_TAG_TOP_K=5
LIFELOG_TAG_THRESHOLD=0.2
# LIFELOG_TAG_LABELS=beach,dog,food,...   # override the default vocabulary
# Video action recognition (Phase 1)
LIFELOG_ACTION_MODEL=microsoft/xclip-base-patch32
LIFELOG_ACTION_TOP_K=3
LIFELOG_ACTION_THRESHOLD=0.3
# LIFELOG_ACTION_LABELS=cooking,running,...  # override the default vocabulary
# Faces (Phase 2) — InsightFace model pack + clustering. buffalo_s fits 8 GB easily.
LIFELOG_FACE_MODEL=buffalo_s
LIFELOG_FACE_DET_THRESHOLD=0.5
LIFELOG_FACE_CLUSTER_THRESHOLD=0.5

# Ollama LLM for chit-chat replies (optional)
# Set LIFELOG_LLM_ENABLED=false to disable and always use the generic fallback.
# Requires Ollama running locally: https://ollama.com
LIFELOG_LLM_ENABLED=true
LIFELOG_OLLAMA_URL=http://localhost:11434
LIFELOG_OLLAMA_MODEL=llama3

# RAG answers + query decomposition (Phase 3). Require LIFELOG_LLM_ENABLED + a reachable
# Ollama. Both degrade gracefully to plain result cards when the LLM is unavailable.
LIFELOG_ENABLE_ANSWERS=true
LIFELOG_QUERY_DECOMPOSITION=true
LIFELOG_ANSWER_MAX_CARDS=5

# Proactive features (Phase 4): on-this-day, digests, insights, auto titles.
LIFELOG_ENABLE_ON_THIS_DAY=true
LIFELOG_ENABLE_DIGESTS=true
LIFELOG_ENABLE_INSIGHTS=true
# Auto card titles add an LLM call per query — opt-in.
LIFELOG_ENABLE_TITLES=false
# Background daily refresh of digests/insights (APScheduler).
LIFELOG_ENABLE_PROACTIVE_SCHEDULE=false
